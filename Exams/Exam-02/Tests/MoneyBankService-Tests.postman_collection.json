		{
			"name": "AddAccount",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200-Ok\", function () {\r",
							"    pm.response.to.have.status(200);\r",
							"});\r",
							"pm.test(\"Valid Data\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    var id = jsonData.id;\r",
							"    var accountNumber = jsonData.accountNumber;\r",
							"    var initialBalanceAmount = jsonData.balanceAmount;\r",
							"\r",
							"    pm.collectionVariables.set(\"id\", id);\r",
							"    pm.collectionVariables.set(\"accountNumber\", accountNumber);\r",
							"    pm.collectionVariables.set(\"initialBalanceAmount\", initialBalanceAmount);\r",
							"    pm.expect(jsonData.id).to.eql(id);\r",
							"    pm.expect(jsonData.accountType).to.eql(\"A\");\r",
							"    pm.expect(jsonData.creationDate).to.eql(\"2023-10-07T00:00:00\");\r",
							"    pm.expect(jsonData.accountNumber).to.eql(\"1234567098\");\r",
							"    pm.expect(jsonData.ownerName).to.eql(\"John Doe\");\r",
							"    pm.expect(jsonData.balanceAmount).to.eql(200000);\r",
							"    pm.expect(jsonData.overdraftAmount).to.eql(1750);\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],

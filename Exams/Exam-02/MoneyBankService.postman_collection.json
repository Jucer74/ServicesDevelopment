							"});\r",
							"\r",
							"pm.test(\"Reponse Assertion\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.collectionVariables.set(\"AccountId\",jsonData.id);\r",
							"    pm.expect(jsonData.id).to.eql(4);\r",
							"    pm.expect(jsonData.accountType).to.eql(\"C\");\r",
							"    pm.expect(jsonData.accountNumber).to.eql(\"6703001329\");\r",
							"    pm.expect(jsonData.ownerName).to.eql(\"John Fredy Vásquez Izquierdo\");\r",
							"    pm.expect(jsonData.balanceAmount).to.eql(\"7000000\");\r",
							"    pm.expect(jsonData.overdraftAmount).to.eql(\"96000000\");\r",
							"});"
